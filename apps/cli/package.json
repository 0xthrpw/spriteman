{
  "name": "@spriteman/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "spriteman": "./bin/spriteman.mjs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').mkdirSync('dist/guide',{recursive:true});require('fs').copyFileSync('src/guide/pixel-art.md','dist/guide/pixel-art.md')\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@spriteman/pixel": "*",
    "@spriteman/shared": "*",
    "commander": "^12.1.0",
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
